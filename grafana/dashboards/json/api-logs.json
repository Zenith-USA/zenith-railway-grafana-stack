{
  "uid": null,
  "title": "API Logs",
  "description": "Logs dashboard for API and iOS app via Loki",
  "schemaVersion": 39,
  "editable": false,
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "tags": ["logs", "loki", "api"],
  "templating": {
    "list": [
      {
        "name": "platform",
        "label": "Platform",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "grafana_lokiq"
        },
        "query": {
          "type": 1,
          "label": "platform",
          "refId": "LokiVariableQueryEditor-VariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "grafana_lokiq"
        },
        "query": {
          "type": 1,
          "label": "service",
          "refId": "LokiVariableQueryEditor-VariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": "DEBUG,INFO,WARNING,ERROR,CRITICAL",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": ["INFO", "WARNING", "ERROR", "CRITICAL"],
          "value": ["INFO", "WARNING", "ERROR", "CRITICAL"]
        },
        "options": [
          { "text": "All", "value": "$__all", "selected": false },
          { "text": "DEBUG", "value": "DEBUG", "selected": false },
          { "text": "INFO", "value": "INFO", "selected": true },
          { "text": "WARNING", "value": "WARNING", "selected": true },
          { "text": "ERROR", "value": "ERROR", "selected": true },
          { "text": "CRITICAL", "value": "CRITICAL", "selected": true }
        ]
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Key Stats",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 100
    },
    {
      "id": 1,
      "title": "Error Rate",
      "description": "Errors per minute",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "grafana_lokiq"
          },
          "expr": "sum(count_over_time({level=\"ERROR\"} [1m]))",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Warning Rate",
      "description": "Warnings per minute",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "grafana_lokiq"
          },
          "expr": "sum(count_over_time({level=\"WARNING\"} [1m]))",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 20 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Critical Count",
      "description": "Critical logs in the last hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "grafana_lokiq"
          },
          "expr": "sum(count_over_time({level=\"CRITICAL\"} [1h]))",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "row",
      "title": "Log Volume",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "id": 101
    },
    {
      "id": 4,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "grafana_lokiq"
          },
          "expr": "sum(count_over_time({level=~\".+\"} [1m])) by (level)",
          "queryType": "range",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 0,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "unit": "short",
          "color": {
            "mode": "fixed"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "DEBUG" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "INFO" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "WARNING" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CRITICAL" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      }
    },
    {
      "id": 5,
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "grafana_lokiq"
          },
          "expr": "sum(count_over_time({service=~\".+\"} [1m])) by (service)",
          "queryType": "range",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 0,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      }
    },
    {
      "type": "row",
      "title": "Error Analysis",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "id": 102
    },
    {
      "id": 6,
      "title": "Error Logs",
      "description": "ERROR and CRITICAL log lines",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "grafana_lokiq"
          },
          "expr": "{platform=~\"$platform\", service=~\"$service\", level=~\"ERROR|CRITICAL\"} |= \"$search\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "type": "row",
      "title": "Platform Views",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "id": 103
    },
    {
      "id": 7,
      "title": "API Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 26 },
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "grafana_lokiq"
          },
          "expr": "{platform=\"api\", service=~\"$service\", level=~\"$level\"} |= \"$search\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 8,
      "title": "Worker Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 26 },
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "grafana_lokiq"
          },
          "expr": "{platform=\"worker\", service=~\"$service\", level=~\"$level\"} |= \"$search\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
